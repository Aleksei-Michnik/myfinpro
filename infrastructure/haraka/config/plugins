# ── Relay ACL ──
# Allow relay from trusted IPs (Docker network containers)
# Without this plugin, Haraka rejects mail to external domains with
# "550 I cannot deliver mail for <recipient>" because connection.relaying is false
relay

# ── DKIM Signing ──
# Sign outbound emails with DKIM using the built-in dkim_sign plugin.
# Note: haraka-plugin-dkim (npm) causes "Cannot pipe while currently piping"
# crash due to a message-stream race condition with queue/deliver.
dkim_sign

# ── Outbound Delivery ──
# Queue and deliver to recipient MX servers
queue/deliver
